ANTHROPIC_API_KEY=your-anthropic-api-key-here

# PostgreSQL (auto-configured in docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/memorywiki

# Redis (auto-configured in docker-compose)
REDIS_URL=redis://redis:6379/0

# MinIO (auto-configured in docker-compose)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=memories
MINIO_USE_SSL=false

# LLM
ANTHROPIC_MODEL=claude-sonnet-4-6
